# ── OpenRouter (cloud LLM — free models) ──
# Get a free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── Google OAuth (login — from https://console.cloud.google.com/apis/credentials) ──
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# ── JWT Secret (change this in production!) ──
JWT_SECRET=rag-enterprise-secret-change-me-in-production

# ── Ollama (optional — local models, defaults to http://localhost:11434) ──
# OLLAMA_BASE_URL=http://localhost:11434
